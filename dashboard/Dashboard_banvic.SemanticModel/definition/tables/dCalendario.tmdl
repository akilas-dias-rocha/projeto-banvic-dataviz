	partition dCalendario = calculated
		mode: import
		source =
				
				CALENDAR (
				    MIN(MIN(fat_propostas_credito[data_entrada_proposta]), MIN(fat_transacoes[data_transacao])),
				    MAX(MAX(fat_propostas_credito[data_entrada_proposta]), MAX(fat_transacoes[data_transacao]))
				)

	annotation PBI_Id = a30ccada98374c2692f98e93c3a39154

